NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000
RUN_WORKER_IN_API=false
MIGRATE_ON_STARTUP=false
DEMO_LOGIN_ENABLED=true

# Leave empty to use the in-memory store for quick API development.
DATABASE_URL=postgres://sentinelflow:sentinelflow@localhost:5432/sentinelflow
REDIS_URL=redis://localhost:6379

SESSION_SECRET=replace-with-32-random-bytes
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=sentinelflow
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret

# Comma-separated repo full names, e.g. anasm266/installsentry,anasm266/any-map
SCAN_REPO_ALLOWLIST=anasm266/installsentry,anasm266/any-map

SCANNER_TIMEOUT_MS=120000
SCANNER_MAX_OUTPUT_BYTES=200000
